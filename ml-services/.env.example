#
# Example environment variables for Welp ML microservices.
# Copy this file to `.env` and adjust values per service before deploying.
#

# Comma-separated list of allowed origins for CORS.
ALLOWED_ORIGINS=https://welphub.onrender.com,http://localhost:5173

# Bind address + port. Each service overrides PORT in its Dockerfile but
# supplying it here lets you run `python main.py` locally without docker.
HOST=0.0.0.0
PORT=8000

# Number of Uvicorn workers to spawn in production.
WEB_CONCURRENCY=2

# Logging verbosity for uvicorn (`critical`, `error`, `warning`, `info`, `debug`, `trace`).
LOG_LEVEL=info

# Avoid tokenizers multiprocessing warnings when transformers is used.
TOKENIZERS_PARALLELISM=false
