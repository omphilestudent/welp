// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  passwordHash  String?
  role          UserRole  @default(EMPLOYEE)
  isAnonymous   Boolean   @default(false)
  displayName   String?
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  reviews       Review[]
  sentMessages  Message[] @relation("SentMessages")
  conversations ConversationParticipant[]
  companies     Company[] @relation("BusinessOwners")
  createdCompanies Company[] @relation("CompanyCreator")
  employeeConversations Conversation[] @relation("EmployeeConversations")
  psychologistConversations Conversation[] @relation("PsychologistConversations")
}

enum UserRole {
  EMPLOYEE
  PSYCHOLOGIST
  BUSINESS
}

model Company {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  industry    String?
  website     String?
  email       String?
  phone       String?
  address     String?
  logoUrl     String?
  isClaimed   Boolean   @default(false)
  createdAt   DateTime  @default(now())

  // Relations
  reviews     Review[]
  owners      User[]    @relation("BusinessOwners")
  createdBy   User?     @relation("CompanyCreator")
  createdById String?
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  content   String
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  replies   Reply[]
}

model Reply {
  id         String   @id @default(cuid())
  content    String
  authorRole UserRole
  createdAt  DateTime @default(now())

  // Relations
  reviewId   String
  review     Review   @relation(fields: [reviewId], references: [id])
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
}

model Conversation {
  id        String   @id @default(cuid())
  status    ConversationStatus @default(PENDING)
  createdAt DateTime @default(now())

  // Relations
  employeeId    String
  employee      User   @relation("EmployeeConversations", fields: [employeeId], references: [id])
  psychologistId String
  psychologist  User   @relation("PsychologistConversations", fields: [psychologistId], references: [id])
  messages      Message[]
}

enum ConversationStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

model Message {
  id             String   @id @default(cuid())
  content        String
  createdAt      DateTime @default(now())

  // Relations
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderId       String
  sender         User     @relation("SentMessages", fields: [senderId], references: [id])
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  userId         String
  conversationId String
  user           User     @relation(fields: [userId], references: [id])
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@unique([userId, conversationId])
}